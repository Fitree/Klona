# Server-side KLONA memory stack configuration.
# Copy to .env with scripts/init_memory_stack.py or by hand. Do not commit .env.

# Host markdown vault path. Mounted only by the low-level memory-server service.
HOST_VAULT_DIR=./vault

# Low-level direct/admin MCP server (vault tools).
LOW_LEVEL_MCP_HOST_PORT=32310
# Empty disables auth. Set a private value to require Bearer auth.
LOW_LEVEL_MCP_AUTH_TOKEN=
# Empty disables DNS rebinding protection and allows all Host headers.
# Set a comma-separated allowlist to enable Host header checks.
LOW_LEVEL_ALLOWED_HOSTS=

# High-level user-agent MCP server (recall/remember tools).
HIGH_LEVEL_MCP_HOST_PORT=32311
# Empty disables auth. Set a private value to require Bearer auth.
HIGH_LEVEL_MCP_AUTH_TOKEN=
# Empty disables DNS rebinding protection and allows all Host headers.
# Set a comma-separated allowlist to enable Host header checks.
HIGH_LEVEL_ALLOWED_HOSTS=

# URL used by memory-agent inside Compose to reach the low-level server.
LOW_LEVEL_MCP_URL=http://memory-server:8000/mcp

# Persisted memory-agent queue/state. The Compose file maps /state to a named Docker volume.
MEMORY_AGENT_QUEUE_DB=/state/queue.db
MEMORY_AGENT_STATE_DIR=/state

# Timeout/retry defaults.
MEMORY_AGENT_TIMEOUT_SECONDS=600
MEMORY_AGENT_MAX_RETRIES=2

# Internal OpenCode serve listener used by the memory-agent container.
OPENCODE_HOST=127.0.0.1
OPENCODE_PORT=4096
