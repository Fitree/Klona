# Empty disables auth. Set a private value to require Bearer auth.
AUTH_TOKEN=
HOST_VAULT_DIR=./vault
# Allowed Host header values (comma-separated). Required when accessing the server
# from a non-localhost address (e.g. via port forwarding or remote access).
# Supports wildcard ports: "example.com:*". Leave empty to disable DNS rebinding protection.
ALLOWED_HOSTS=
